# Copy this file to `keystore.properties` (which is gitignored) for LOCAL release signing.
# CI uses GitHub Actions secrets instead (see .github/workflows/build.yml), so this file
# is only needed if you want to build a signed release on your own machine.
storeFile=/absolute/path/to/corewatch-release.jks
storePassword=CHANGE_ME
keyAlias=corewatch
keyPassword=CHANGE_ME
